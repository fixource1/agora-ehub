# NativePHP / Android build overrides (merged into .env before each Windows build).
# Edit THIS file - not .env - so WSL sync does not wipe your mobile API settings.
#
# After changing values: npm run build, then scripts\native-run-android.cmd

MOBILE_API_ENABLED=true
# Use auto-detection during Windows builds (setup-android-api-access.ps1),
# or set manually: http://<WSL-IP>:8000 | http://10.0.2.2:8000 | http://<LAN-IP>:8000
MOBILE_API_BASE_URL=auto
CORS_ALLOWED_ORIGINS=*

# Bump on every bundle change so the emulator installs the new APK assets.
NATIVEPHP_APP_VERSION_CODE=21
