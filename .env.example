APP_NAME="AGORA e-Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=agora_ehub
DB_USERNAME=agora_ehub
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@agora-ehub.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

APP_PORT=8080
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
VITE_PORT=5173

# NativePHP Mobile (run native:install from Windows CMD, not WSL)
NATIVEPHP_APP_ID=com.uplb.agora.ehub
NATIVEPHP_APP_VERSION=1.0.0
NATIVEPHP_APP_VERSION_CODE=3
NATIVEPHP_START_URL=/home
NATIVEPHP_DEEPLINK_SCHEME=agora-ehub
NATIVEPHP_DEEPLINK_HOST=agora-ehub.local

# Mobile app data source — edit config/nativephp.env (merged before Windows builds), not .env on Windows.
# false = embedded SQLite on device | true = live API from WSL Docker via 10.0.2.2:8080
MOBILE_API_ENABLED=false
MOBILE_API_BASE_URL=http://10.0.2.2:8080
CORS_ALLOWED_ORIGINS=*

# Performance (production API)
AGORA_ENSURE_SAMPLE_FILES_ON_DOWNLOAD=false
# Load test base URL (inside Docker: http://nginx)
AGORA_SIMULATE_BASE_URL=
AGORA_CATALOG_CACHE_SECONDS=120
AGORA_RESOURCE_SHOW_CACHE_SECONDS=600
